---
import { Image } from "astro:assets";
import Logo from "../assets/images/Logo.png";

const year = new Date().getFullYear();
const waHref = "https://wa.me/642102834953";
---

<footer class="bg-[#006400] text-white">
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <Image src={Logo} alt="ImpressioNZ Outdoors" height={48} loading="lazy" class="h-12 w-auto brightness-0 invert mb-4" densities={[1, 2, 3]} />
      <p class="text-white text-sm leading-relaxed opacity-90">
        Garden creation and maintenance in Auckland.<br />
        Sole trader.
      </p>
    </div>

    <div>
      <h3 class="font-serif font-bold mb-4 text-lg text-white">Services</h3>
      <ul class="space-y-2 text-sm text-white opacity-90">
        {[
          { label: "Planting", anchor: "service-planting" },
          { label: "Lawn care & creation", anchor: "service-lawncare-and-lawn-creation" },
          { label: "Landscaping", anchor: "service-landscaping" },
          { label: "Tree removal & pruning", anchor: "service-tree-removal-and-pruning" },
          { label: "Hedge trimming", anchor: "service-hedge-trimming-and-hedge-reduction" },
          { label: "Garden maintenance", anchor: "service-garden-maintenance-and-consulting" },
          { label: "Stump grinding", anchor: "service-stump-grinding" },
          { label: "Waste removal", anchor: "service-waste-and-fence-removal" },
        ].map(({ label, anchor }) => (
          <li>
            <a href={`/services#${anchor}`} class="hover:text-white transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-serif font-bold mb-4 text-lg text-white">Get in touch</h3>
      <ul class="space-y-3 text-sm text-white opacity-90">
        <li>
          <a href="tel:+642102834953" class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            021 0283 4953
          </a>
        </li>
        <li>
          <a href={waHref} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </li>
        <li>
          <a href="mailto:impressionzoutdoors@gmail.com" class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            impressionzoutdoors@gmail.com
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/profile.php?id=61573614954159"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors flex items-center gap-2"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
            Facebook
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/20">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white opacity-80">
      <span>© {year} ImpressioNZ Outdoors. All rights reserved.</span>
      <a href="/terms" class="hover:text-white transition-colors">Terms & Conditions</a>
    </div>
  </div>
</footer>
