---
const year = new Date().getFullYear();
---

<footer class="bg-[#006400] text-white">
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <img src="/images/Logo.png" alt="ImpressioNZ Outdoors" class="h-12 w-auto brightness-0 invert mb-4" />
      <p class="text-white/80 text-sm leading-relaxed">
        Garden creation and maintenance in Auckland.<br />
        Sole trader — you deal directly with Rod.
      </p>
    </div>

    <div>
      <h3 class="font-serif font-bold mb-4 text-lg text-white">Services</h3>
      <ul class="space-y-2 text-sm text-white/80">
        {[
          "Planting",
          "Lawn care & creation",
          "Landscaping",
          "Tree removal & pruning",
          "Hedge trimming",
          "Garden maintenance",
          "Stump grinding",
          "Waste removal",
        ].map((s) => (
          <li>
            <a href="/services" class="hover:text-white transition-colors">{s}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-serif font-bold mb-4 text-lg text-white">Get in touch</h3>
      <ul class="space-y-3 text-sm text-white/80">
        <li>
          <a href="tel:+64210283 4953" class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            021 0283 4953
          </a>
        </li>
        <li>
          <a href="mailto:impressionzoutdoors@gmail.com" class="hover:text-white transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            impressionzoutdoors@gmail.com
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/profile.php?id=61573614954159"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors flex items-center gap-2"
          >
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
            Facebook
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/20">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/70">
      <span>© {year} ImpressioNZ Outdoors. All rights reserved.</span>
      <a href="/terms" class="hover:text-white transition-colors">Terms & Conditions</a>
    </div>
  </div>
</footer>
