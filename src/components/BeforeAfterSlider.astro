---
interface Props {
  beforeSrc: string;
  afterSrc: string;
  beforeAlt: string;
  afterAlt: string;
}

const { beforeSrc, afterSrc, beforeAlt, afterAlt } = Astro.props;
---

<div
  class="ba-root relative select-none overflow-hidden rounded-lg shadow-lg max-w-3xl mx-auto aspect-[16/9] cursor-col-resize"
  role="img"
  aria-label="Before and after comparison — use arrow keys to adjust"
  tabindex="0"
>
  <img
    src={afterSrc}
    alt={afterAlt}
    class="absolute inset-0 w-full h-full object-cover"
    draggable="false"
  />
  <img
    src={beforeSrc}
    alt={beforeAlt}
    class="ba-before absolute inset-0 w-full h-full object-cover"
    style="clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%)"
    draggable="false"
  />
  <div class="ba-divider absolute top-0 bottom-0 w-0.5 bg-white shadow-lg pointer-events-none" style="left: 50%">
    <div class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center">
      <svg class="w-5 h-5 text-[#006400]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l-3 3 3 3M16 9l3 3-3 3"/>
      </svg>
    </div>
  </div>
  <span class="absolute top-4 left-4 bg-black/60 text-white text-xs font-semibold px-2 py-1 rounded pointer-events-none">Before</span>
  <span class="absolute top-4 right-4 bg-black/60 text-white text-xs font-semibold px-2 py-1 rounded pointer-events-none">After</span>
</div>

<script>
  document.querySelectorAll('.ba-root').forEach((sliderEl) => {
    const slider = sliderEl as HTMLElement;
    const before = slider.querySelector('.ba-before') as HTMLElement;
    const divider = slider.querySelector('.ba-divider') as HTMLElement;
    let dragging = false;
    let pct = 50;

    function setPosition(clientX: number) {
      const rect = slider.getBoundingClientRect();
      pct = Math.min(Math.max((clientX - rect.left) / rect.width, 0), 1) * 100;
      before.style.clipPath = `polygon(0 0, ${pct}% 0, ${pct}% 100%, 0 100%)`;
      divider.style.left = `${pct}%`;
    }

    slider.addEventListener("mousedown", (e) => { dragging = true; setPosition((e as MouseEvent).clientX); });
    window.addEventListener("mouseup", () => { dragging = false; });
    window.addEventListener("mousemove", (e) => { if (dragging) setPosition((e as MouseEvent).clientX); });
    slider.addEventListener("touchstart", (e) => { dragging = true; setPosition((e as TouchEvent).touches[0]!.clientX); }, { passive: true });
    window.addEventListener("touchend", () => { dragging = false; });
    window.addEventListener("touchmove", (e) => { if (dragging) setPosition((e as TouchEvent).touches[0]!.clientX); }, { passive: true });
    slider.addEventListener("keydown", (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === "ArrowRight") pct = Math.min(pct + 5, 100);
      else if (ke.key === "ArrowLeft") pct = Math.max(pct - 5, 0);
      else return;
      e.preventDefault();
      before.style.clipPath = `polygon(0 0, ${pct}% 0, ${pct}% 100%, 0 100%)`;
      divider.style.left = `${pct}%`;
    });
  });
</script>
