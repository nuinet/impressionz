---
const phone = "021 0283 4953";
const phoneHref = "tel:+6421028 34953";
const fbUrl = "https://www.facebook.com/profile.php?id=61573614954159";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 h-16 grid grid-cols-[1fr_auto_1fr] items-center">

    <!-- Left: phone + FB on desktop | hamburger on mobile -->
    <div class="flex items-center gap-4">
      <!-- Mobile: hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 -ml-2 rounded text-[#303a4d] hover:text-[#006400] transition-colors"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- Desktop: phone + Facebook -->
      <a
        href={phoneHref}
        class="hidden md:flex items-center gap-1.5 text-sm font-medium text-[#303a4d] hover:text-[#006400] transition-colors"
        aria-label={`Call us at ${phone}`}
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {phone}
      </a>
      <a
        href={fbUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:flex items-center text-[#303a4d] hover:text-[#006400] transition-colors"
        aria-label="Visit our Facebook page"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
      </a>
    </div>

    <!-- Center: logo -->
    <a href="/" aria-label="ImpressioNZ Outdoors — Home">
      <img src="/images/Logo.png" alt="ImpressioNZ Outdoors" class="h-10 w-auto" width="150" height="40" />
    </a>

    <!-- Right: nav on desktop | tap-to-call on mobile -->
    <div class="flex items-center justify-end">
      <!-- Mobile: phone icon -->
      <a
        href={phoneHref}
        class="md:hidden p-2 text-[#006400]"
        aria-label={`Call us at ${phone}`}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
      </a>

      <!-- Desktop: nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={currentPath === link.href ? "page" : undefined}
            class:list={[
              "text-sm font-medium transition-colors hover:text-[#006400]",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "text-[#006400] border-b-2 border-[#006400] pb-0.5"
                : "text-[#303a4d]",
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white"
    aria-label="Mobile navigation"
  >
    <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={currentPath === link.href ? "page" : undefined}
          class:list={[
            "px-3 py-2.5 rounded text-sm font-medium transition-colors",
            currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
              ? "bg-gray-50 text-[#006400]"
              : "text-[#303a4d] hover:bg-gray-50",
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="mt-2 pt-2 border-t border-gray-100 flex items-center gap-4 px-3 pb-1">
        <a
          href={fbUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#303a4d] hover:text-[#006400] transition-colors"
          aria-label="Visit our Facebook page"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;
  const iconOpen = document.getElementById("menu-icon-open")!;
  const iconClose = document.getElementById("menu-icon-close")!;

  btn.addEventListener("click", () => {
    const isOpen = !menu.classList.contains("hidden");
    menu.classList.toggle("hidden", isOpen);
    btn.setAttribute("aria-expanded", String(!isOpen));
    iconOpen.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
  });

  menu.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
      iconOpen.classList.remove("hidden");
      iconClose.classList.add("hidden");
    })
  );
</script>
