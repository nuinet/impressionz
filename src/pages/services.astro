---
import Layout from "../layouts/Layout.astro";
import BeforeAfterSlider from "../components/BeforeAfterSlider.astro";
import { getCollection } from "astro:content";

const rawServices = await getCollection("services");
const services = rawServices
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((e) => ({ id: e.id, ...e.data }));
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://impressionz.co.nz/" },
    { "@type": "ListItem", position: 2, name: "Services", item: "https://impressionz.co.nz/services" },
  ],
};

const serviceList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "ImpressioNZ Outdoors — Services",
  itemListElement: services.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Service",
      name: s.title,
      description: s.description,
      provider: { "@type": "LandscapingBusiness", name: "ImpressioNZ Outdoors" },
    },
  })),
};
---

<Layout
  title="Services — ImpressioNZ Outdoors Auckland"
  description="Auckland gardening and landscaping services: planting, lawn care, tree removal, hedge trimming, landscaping, stump grinding, garden maintenance and waste removal."
  schema={[breadcrumb, serviceList]}
>
  <!-- Page header -->
  <section class="bg-[--color-surface] border-b border-gray-200 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-[--color-brand-dark] font-medium uppercase tracking-wide text-sm mb-3">What we offer</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">Expert outdoor services in Auckland</h1>
      <p class="text-gray-600 max-w-2xl text-lg leading-relaxed">
        We increase and retain the value of your property by creating and maintaining outdoor spaces
        you actually want to spend time in. All work is quoted in writing before it starts.
      </p>
    </div>
  </section>

  <!-- Before / After -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="font-serif text-3xl font-bold mb-2">Before & after</h2>
        <p class="text-gray-500">Drag the slider to compare</p>
      </div>
      <BeforeAfterSlider
        beforeSrc="/images/Antes 1.jpg"
        afterSrc="/images/Después 1.jpg"
        beforeAlt="Garden before transformation"
        afterAlt="Garden after transformation by ImpressioNZ"
      />
    </div>
  </section>

  <!-- Services list -->
  <section class="py-16 bg-[--color-surface]">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-serif text-3xl font-bold mb-10">All services</h2>
      <div class="space-y-4" id="services-accordion">
        {services.map((service) => (
          <div class="bg-white rounded-lg shadow-sm overflow-hidden border border-gray-100">
            <button
              class="w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-[--color-surface] transition-colors"
              aria-expanded="false"
              aria-controls={`service-${service.id}`}
              data-accordion-btn
            >
              <span class="font-serif text-lg font-bold">{service.title}</span>
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 transition-transform" data-accordion-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id={`service-${service.id}`} class="hidden px-6 pb-6" data-accordion-content>
              <p class="text-gray-700 leading-relaxed mb-4">{service.description}</p>
              <p class="text-sm text-[--color-brand-muted] bg-[--color-surface] rounded p-3 leading-relaxed">
                {service.detail}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="font-serif text-3xl font-bold mb-4">Not sure what you need?</h2>
      <p class="text-gray-600 mb-8 text-lg">
        Rod visits your property, assesses the space, and tells you exactly what's needed — and what isn't.
        The assessment is free and there's no obligation to proceed.
      </p>
      <a
        href="/contact"
        class="inline-block bg-[#90ee90] text-[#303a4d] hover:bg-[#006400] hover:text-white font-bold px-8 py-4 rounded-[30px] transition-colors"
      >
        Get a free, no-obligation quote
      </a>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll("[data-accordion-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      const content = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector("[data-accordion-icon]") as SVGElement;

      // Close all
      document.querySelectorAll("[data-accordion-btn]").forEach((b) => {
        b.setAttribute("aria-expanded", "false");
        (b.nextElementSibling as HTMLElement).classList.add("hidden");
        (b.querySelector("[data-accordion-icon]") as SVGElement).style.transform = "";
      });

      // Open clicked (unless it was already open)
      if (!isOpen) {
        btn.setAttribute("aria-expanded", "true");
        content.classList.remove("hidden");
        icon.style.transform = "rotate(180deg)";
      }
    });
  });
</script>
