---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const termsCollection = await getCollection("terms");
const { items } = termsCollection[0]!.data;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://impressionz.co.nz/" },
    { "@type": "ListItem", position: 2, name: "Terms & Conditions", item: "https://impressionz.co.nz/terms" },
  ],
};
---

<Layout
  title="Terms & Conditions — ImpressioNZ Outdoors"
  schema={breadcrumb}
  description="Terms and conditions for ImpressioNZ Outdoors garden and landscaping services in Auckland."
>
  <section class="bg-[--color-surface] border-b border-gray-200 py-12">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="font-serif text-4xl font-bold">Terms & Conditions</h1>
      <p class="text-gray-500 mt-2 text-sm">ImpressioNZ Outdoors — Rod MacKenzie BA Hons (UCT) MCW (University of Auckland)</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4">
      <div class="prose prose-green max-w-none text-gray-700 space-y-6 text-sm leading-relaxed">
        <ol class="space-y-6 list-decimal list-outside pl-5">
          {items.map(({ heading, body }) => (
            <li>
              <strong>{heading}.</strong> {body}
            </li>
          ))}
        </ol>
      </div>
      <div class="mt-10">
        <a href="/contact" class="inline-block bg-[#303a4d] text-white hover:bg-[#006400] font-semibold px-6 py-3 rounded-[30px] transition-colors text-sm">
          ← Back to contact
        </a>
      </div>
    </div>
  </section>
</Layout>
