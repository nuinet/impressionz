---
import Layout from "../layouts/Layout.astro";
import BeforeAfterSlider from "../components/BeforeAfterSlider.astro";
import { getCollection } from "astro:content";

const rawGallery = await getCollection("gallery");

const items = rawGallery
  .filter((e) => {
    const d = e.data.media.discriminant;
    if (d === "image") return !!e.data.media.value.image;
    if (d === "video") return !!(e.data.media.value as { videoUrl?: string }).videoUrl;
    if (d === "before-after") {
      const v = e.data.media.value as { beforeImage?: string; afterImage?: string };
      return !!(v.beforeImage && v.afterImage);
    }
    return false;
  })
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((e) => {
    const d = e.data.media;
    const type = d.discriminant;
    const imgVal = d.value as { image?: string };
    const vidVal = d.value as { image?: string; videoUrl?: string };
    const baVal = d.value as { beforeImage?: string; afterImage?: string };
    return {
      src: type === "image" ? (imgVal.image ?? null) : type === "video" ? (vidVal.image ?? null) : null,
      alt: e.data.alt,
      title: e.data.title,
      description: e.data.description ?? "",
      mediaType: type as "image" | "video" | "before-after",
      videoUrl: type === "video" ? (vidVal.videoUrl ?? null) : null,
      beforeImage: type === "before-after" ? (baVal.beforeImage ?? null) : null,
      afterImage: type === "before-after" ? (baVal.afterImage ?? null) : null,
    };
  });

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://impressionz.co.nz/" },
    { "@type": "ListItem", position: 2, name: "Gallery", item: "https://impressionz.co.nz/gallery/" },
  ],
};
---

<Layout
  title="Gallery — ImpressioNZ Outdoors"
  description="Photos of garden transformations, landscaping, planting, and maintenance work by Rod MacKenzie in Auckland."
  schema={breadcrumbSchema}
>
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <h1 class="font-serif text-4xl font-bold text-[#006400] mb-2">Gallery</h1>
    <p class="text-gray-600 mb-10">A selection of garden transformations and projects across Auckland.</p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {items.map((item, i) => (
        <button
          class="group relative aspect-[4/3] overflow-hidden rounded-lg shadow-sm hover:shadow-md transition-shadow focus:outline-none focus:ring-2 focus:ring-[#006400]"
          data-gallery-index={i}
          aria-label={`View ${item.alt}`}
        >
          {item.mediaType === "before-after" ? (
            <div class="flex w-full h-full">
              <div class="w-1/2 overflow-hidden">
                <img
                  src={item.beforeImage!}
                  alt={`Before: ${item.alt}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="w-px bg-white/60 shrink-0 z-10"></div>
              <div class="w-1/2 overflow-hidden">
                <img
                  src={item.afterImage!}
                  alt={`After: ${item.alt}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
          ) : (
            <>
              <img
                src={item.src!}
                alt={item.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              {item.mediaType === "video" && (
                <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/40 transition-colors">
                  <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-[#006400] ml-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              )}
            </>
          )}
        </button>
      ))}
    </div>
  </section>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 bg-black/90 hidden items-center justify-center"
    role="dialog"
    aria-modal="true"
    aria-label="Image lightbox"
  >
    <button
      id="lb-close"
      class="absolute top-4 right-4 text-white hover:text-gray-300 transition-colors p-2"
      aria-label="Close lightbox"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <button
      id="lb-prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 text-white hover:text-gray-300 transition-colors p-2"
      aria-label="Previous image"
    >
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>

    <div class="flex flex-col items-center w-full px-16 max-h-[95vh]">
      <!-- Media area -->
      <div class="max-w-5xl w-full flex items-center justify-center">
        <img id="lb-img" src="" alt="" class="max-w-full max-h-[70vh] object-contain rounded" />
        <iframe
          id="lb-video"
          class="hidden w-full aspect-video rounded"
          style="max-height: 70vh;"
          src=""
          title="Video player"
          allow="autoplay; fullscreen"
          allowfullscreen
        ></iframe>
        <!-- Before-after slider slots (pre-rendered, shown/hidden by JS) -->
        <div id="lb-ba-container" class="hidden w-full">
          {items.map((item, i) => item.mediaType === "before-after" && (
            <div data-ba-slot={i} style="display:none">
              <BeforeAfterSlider
                beforeSrc={item.beforeImage!}
                afterSrc={item.afterImage!}
                beforeAlt={`Before: ${item.alt}`}
                afterAlt={`After: ${item.alt}`}
              />
              <p class="text-white/50 text-xs text-center mt-2">Drag to compare</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Description (centred, hidden when empty) -->
      <div id="lb-description" class="hidden text-white/80 text-sm text-center px-4 mt-3 leading-relaxed max-w-xl"></div>

      <!-- Counter -->
      <div id="lb-counter" aria-live="polite" class="text-white text-sm font-medium mt-2"></div>
    </div>

    <button
      id="lb-next"
      class="absolute right-4 top-1/2 -translate-y-1/2 text-white hover:text-gray-300 transition-colors p-2"
      aria-label="Next image"
    >
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
  </div>
</Layout>

<script define:vars={{ galleryItems: items.map(e => ({
  src: e.src,
  alt: e.alt,
  description: e.description,
  mediaType: e.mediaType,
  videoUrl: e.videoUrl,
  beforeImage: e.beforeImage,
  afterImage: e.afterImage,
})) }} is:inline>
  const lightbox = document.getElementById("lightbox");
  const lbImg = document.getElementById("lb-img");
  const lbVideo = document.getElementById("lb-video");
  const lbBaContainer = document.getElementById("lb-ba-container");
  const lbDescription = document.getElementById("lb-description");
  const lbCounter = document.getElementById("lb-counter");
  let current = 0;

  function getEmbedUrl(url) {
    if (!url) return null;
    const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
    if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}?autoplay=1`;
    const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
    if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}?autoplay=1`;
    return url;
  }

  function open(index) {
    current = index;
    update();
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
    document.getElementById("lb-close").focus();
  }

  function close() {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
    lbVideo.src = "";
  }

  function update() {
    const item = galleryItems[current];
    lbCounter.textContent = `${current + 1} / ${galleryItems.length}`;

    // Description
    if (item.description) {
      lbDescription.textContent = item.description;
      lbDescription.classList.remove("hidden");
    } else {
      lbDescription.textContent = "";
      lbDescription.classList.add("hidden");
    }

    // Media
    if (item.mediaType === "before-after") {
      lbImg.classList.add("hidden");
      lbVideo.classList.add("hidden");
      lbVideo.src = "";
      lbBaContainer.classList.remove("hidden");
      lbBaContainer.querySelectorAll("[data-ba-slot]").forEach((slot) => {
        slot.style.display = slot.dataset.baSlot === String(current) ? "block" : "none";
      });
    } else if (item.mediaType === "video" && item.videoUrl) {
      lbBaContainer.classList.add("hidden");
      lbImg.classList.add("hidden");
      lbVideo.classList.remove("hidden");
      lbVideo.src = getEmbedUrl(item.videoUrl);
    } else {
      lbBaContainer.classList.add("hidden");
      lbVideo.classList.add("hidden");
      lbVideo.src = "";
      lbImg.classList.remove("hidden");
      lbImg.src = item.src;
      lbImg.alt = item.alt;
    }
  }

  function prev() { current = (current - 1 + galleryItems.length) % galleryItems.length; update(); }
  function next() { current = (current + 1) % galleryItems.length; update(); }

  document.querySelectorAll("[data-gallery-index]").forEach((btn) => {
    btn.addEventListener("click", () => open(Number(btn.dataset.galleryIndex)));
  });

  document.getElementById("lb-close").addEventListener("click", close);
  document.getElementById("lb-prev").addEventListener("click", prev);
  document.getElementById("lb-next").addEventListener("click", next);

  lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); });

  document.addEventListener("keydown", (e) => {
    if (lightbox.classList.contains("hidden")) return;
    if (e.target && e.target.closest && e.target.closest(".ba-root")) return;
    if (e.key === "Escape") { close(); return; }
    if (e.key === "ArrowLeft") { prev(); return; }
    if (e.key === "ArrowRight") { next(); return; }
    if (e.key === "Tab") {
      var focusable = Array.from(lightbox.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'));
      if (focusable.length === 0) return;
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
  });
</script>
