---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm";

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://impressionz.co.nz/" },
    { "@type": "ListItem", position: 2, name: "Contact", item: "https://impressionz.co.nz/contact" },
  ],
};
---

<Layout
  title="Contact ImpressioNZ Outdoors — Free Garden Assessment Auckland"
  description="Get a free, no-obligation garden assessment from Rod. Contact ImpressioNZ Outdoors in Auckland by phone, email, or the enquiry form."
  schema={breadcrumb}
>
  <section class="bg-[--color-surface] border-b border-gray-200 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-[--color-brand-dark] font-medium uppercase tracking-wide text-sm mb-3">Get in touch</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">Request a free assessment</h1>
      <p class="text-gray-600 max-w-2xl text-lg leading-relaxed">
        Fill in the form below and Rod will get back to you within two business days to arrange a visit.
        No obligation.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Contact details sidebar -->
      <div class="space-y-8">
        <div>
          <h2 class="font-serif text-xl font-bold mb-4">Contact details</h2>
          <ul class="space-y-4 text-sm">
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">Phone</p>
                <a href="tel:+6421 02834953" class="text-[--color-brand-dark] hover:underline">021 0283 4953</a>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <a href="mailto:impressionzoutdoors@gmail.com" class="text-[--color-brand-dark] hover:underline break-all">impressionzoutdoors@gmail.com</a>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">Facebook</p>
                <a href="https://www.facebook.com/profile.php?id=61573614954159" target="_blank" rel="noopener noreferrer" class="text-[--color-brand-dark] hover:underline">ImpressioNZ Outdoors</a>
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-[--color-surface] rounded-lg p-5 text-sm leading-relaxed">
          <h3 class="font-semibold mb-2">What to include</h3>
          <ul class="space-y-1.5 text-gray-600">
            <li>• Your address or suburb</li>
            <li>• What you'd like done</li>
            <li>• Photos if you have them</li>
            <li>• When you'd like work to happen</li>
          </ul>
          <p class="mt-3 text-gray-500 text-xs">
            A booking deposit is required to secure your date.
            See <a href="/terms" class="text-[--color-brand-dark] underline">terms & conditions</a> for details.
          </p>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-2">
        <ContactForm client:load />
      </div>
    </div>
  </section>
</Layout>
