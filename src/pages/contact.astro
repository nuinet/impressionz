---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm";

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://impressionz.co.nz/" },
    { "@type": "ListItem", position: 2, name: "Contact", item: "https://impressionz.co.nz/contact" },
  ],
};
---

<Layout
  title="Contact ImpressioNZ Outdoors — Free Garden Assessment Auckland"
  description="Get a free, no-obligation garden assessment from Rod. Contact ImpressioNZ Outdoors in Auckland by phone, email, or the enquiry form."
  schema={breadcrumb}
>
  <section class="bg-[--color-surface] border-b border-gray-200 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-[--color-brand-dark] font-medium uppercase tracking-wide text-sm mb-3">Get in touch</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">Request a free, no-obligation quote</h1>
      <p class="text-gray-600 max-w-2xl text-lg leading-relaxed">
        Fill in the form below and Rod will get back to you within two business days to arrange a visit.
        No obligation.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Contact details sidebar -->
      <div class="space-y-8">
        <div>
          <h2 class="font-serif text-xl font-bold mb-4">Contact details</h2>
          <ul class="space-y-4 text-sm">
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">Phone</p>
                <a href="tel:+64210283​4953" class="text-[--color-brand-dark] hover:underline">021 0283 4953</a>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[#25D366] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">WhatsApp</p>
                <a href="https://wa.me/64210283​4953" target="_blank" rel="noopener noreferrer" class="text-[--color-brand-dark] hover:underline">021 0283 4953</a>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <a href="mailto:impressionzoutdoors@gmail.com" class="text-[--color-brand-dark] hover:underline break-all">impressionzoutdoors@gmail.com</a>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-[--color-brand-dark] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900">Facebook</p>
                <a href="https://www.facebook.com/profile.php?id=61573614954159" target="_blank" rel="noopener noreferrer" class="text-[--color-brand-dark] hover:underline">ImpressioNZ Outdoors</a>
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-[--color-surface] rounded-lg p-5 text-sm leading-relaxed">
          <h3 class="font-semibold mb-2">What to include</h3>
          <ul class="space-y-1.5 text-gray-600">
            <li>• Your address or suburb</li>
            <li>• What you'd like done</li>
            <li>• Photos if you have them</li>
            <li>• When you'd like work to happen</li>
          </ul>
          <p class="mt-3 text-gray-600 text-xs font-medium">
            Primarily serving: North Shore, Browns Bay, and surrounding Auckland suburbs.
          </p>
          <p class="mt-2 text-gray-500 text-xs">
            A booking deposit is required to secure your date.
            See <a href="/terms" class="text-[--color-brand-dark] underline">terms & conditions</a> for details.
          </p>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-2">
        <ContactForm client:only="react" />
      </div>
    </div>
  </section>
</Layout>
