---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Message sent — ImpressioNZ Outdoors"
  description="Thank you for contacting ImpressioNZ Outdoors."
>
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-[--color-brand-dark]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="font-serif text-3xl font-bold mb-4">Message sent</h1>
      <p class="text-gray-600 text-lg mb-8">
        Thanks for getting in touch. Rod will get back to you within two business days.
      </p>
      <a href="/" class="inline-block bg-[--color-brand-dark] hover:bg-[--color-brand-mid] text-white font-semibold px-6 py-3 rounded transition-colors">
        Back to home
      </a>
    </div>
  </section>
</Layout>
